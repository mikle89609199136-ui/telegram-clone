############################################################
#                    CORE ENVIRONMENT
############################################################

# Environment: development | production
NODE_ENV=development

# Server port
PORT=3000

# Allowed frontend origin (IMPORTANT in production)
# Example: https://yourdomain.com
CORS_ORIGIN=http://localhost:3000


############################################################
#                    JWT SECURITY
############################################################

# MUST be at least 32+ characters in production
JWT_SECRET=your_super_long_secure_access_token_secret_here_min_32_chars

# MUST be at least 32+ characters in production
JWT_REFRESH_SECRET=your_super_long_secure_refresh_token_secret_here_min_32_chars

# Token expiration
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d


############################################################
#                    PASSWORD HASHING
############################################################

# bcrypt salt rounds (10–14 recommended)
BCRYPT_ROUNDS=12


############################################################
#                    RATE LIMITING
############################################################

# Rate limit window in milliseconds
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window per IP
RATE_LIMIT_MAX=500


############################################################
#                    BODY SIZE LIMIT
############################################################

BODY_LIMIT=10mb


############################################################
#                    SOCKET SETTINGS
############################################################

SOCKET_PING_TIMEOUT=20000
SOCKET_PING_INTERVAL=25000


############################################################
#                    AI CONFIGURATION
############################################################

# true | false
AI_ENABLED=true

# mock | openai | custom
AI_PROVIDER=mock

# Example: gpt-4, gpt-4o, etc.
AI_MODEL=gpt-4

# Timeout for AI response (ms)
AI_TIMEOUT_MS=30000

# Max tokens for AI response
AI_MAX_TOKENS=2048


############################################################
#                    STORAGE CONFIG
############################################################

# file | postgres
STORAGE_TYPE=file

# Required if STORAGE_TYPE=postgres
DATABASE_URL=postgresql://user:password@localhost:5432/messenger


############################################################
#                    REDIS (OPTIONAL SCALING)
############################################################

# true | false
REDIS_ENABLED=false

# Required if REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379


############################################################
#                    UPLOAD SETTINGS
############################################################

# Max upload size (bytes)
UPLOAD_MAX_SIZE=20971520

# Allowed MIME types (comma separated)
UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,application/pdf


############################################################
#                    LOGGING
############################################################

# debug | info | warn | error
LOG_LEVEL=debug

# true | false
ENABLE_REQUEST_LOG=true


############################################################
#                    FEATURE FLAGS
############################################################

# Toggle advanced features
ENABLE_MODERATION=true
ENABLE_TYPING_INDICATOR=true
ENABLE_READ_RECEIPTS=true
ENABLE_DELIVERY_RECEIPTS=true
ENABLE_DEVICE_SYNC=true
ENABLE_ADMIN_PANEL=true
