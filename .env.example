# Server
NODE_ENV=production
PORT=3000
SERVICE=api

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/craheapp
DATABASE_REPLICA_URL=postgresql://user:pass@replica:5432/craheapp

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_ROUNDS=12

# S3 / MinIO
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=craheapp
S3_USE_SSL=false
CDN_URL=http://localhost:9000/craheapp

# Queue (Bull)
QUEUE_URL=redis://localhost:6379

# AI
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4
AI_RATE_LIMIT=10
AI_MAX_TOKENS=1000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
SOCKET_RATE_LIMIT=10

# Upload
UPLOAD_LIMIT=104857600
MAX_MESSAGE_SIZE=10485760

# Security
SESSION_SECRET=session_secret_here
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
